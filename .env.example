# Canvas LMS API Configuration
# Generate a token at: https://<your-school>.instructure.com/profile/settings
# Under "Approved Integrations", click "+ New Access Token"
CANVAS_API_TOKEN=your_canvas_api_token_here

# Your Canvas instance URL (no trailing slash)
# Examples:
#   https://myschool.instructure.com
#   https://canvas.university.edu
CANVAS_BASE_URL=https://yourschool.instructure.com
